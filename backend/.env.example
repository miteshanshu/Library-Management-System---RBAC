PORT=5000
NODE_ENV=development
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRY=24h

# Neon pooled PostgreSQL connection string
DATABASE_URL=postgresql://neondb_owner:<REPLACE_PASSWORD>@ep-icy-mouse-am1jsjkk-pooler.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require

# Application schema
DB_SCHEMA=library_app

# Optional pool tuning
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000
DB_MAX_USES=7500
DB_RETRY_ATTEMPTS=3
DB_RETRY_DELAY_MS=250
